APP_NAME=Curalink API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173
MONGODB_URL=mongodb://localhost:27017/curalink
# Ollama (local dev — used when GROQ_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:e4b
# Groq (cloud — takes priority when set)
GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=gemma2-9b-it
DEFAULT_CANDIDATE_TARGET=150
